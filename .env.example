# =============================================================
#  Szablon zmiennych środowiskowych — SKOPIUJ do .env
#  cp .env.example .env
#  Wartości domyślne są bezpieczne do uruchomienia lokalnego (dev).
#  NIGDY nie commituj pliku .env do repozytorium.
# =============================================================

# ---- Baza danych (PostgreSQL) ----
POSTGRES_USER=cinema
POSTGRES_PASSWORD=cinema_dev_password
POSTGRES_DB=cinema

# Connection string używany przez Prisma w kontenerze backendu.
# Host "db" to nazwa serwisu z docker-compose.yml.
DATABASE_URL=postgresql://cinema:cinema_dev_password@db:5432/cinema?schema=public

# ---- Backend ----
NODE_ENV=development
PORT=3000

# Sekrety JWT — w produkcji WYGENERUJ własne, min. 32 losowe znaki.
# Przykład generowania: openssl rand -base64 48
JWT_ACCESS_SECRET=dev_access_secret_change_me_min_32_characters_long
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_min_32_characters_long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Origin frontendu (CORS whitelist) — nie używać "*".
CORS_ORIGIN=http://localhost:5173

# ---- Frontend ----
# Adres API widziany z przeglądarki (nie z wnętrza kontenera).
VITE_API_URL=http://localhost:3000
